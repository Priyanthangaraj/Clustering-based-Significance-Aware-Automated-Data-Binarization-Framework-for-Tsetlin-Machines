# Function to preprocess the dataset: handling categorical encoding and separating features and labels
def preprocess_dataset(file_path):
    df = pd.read_csv(file_path)

    # Identify and encode categorical columns
    categorical_cols = df.select_dtypes(include=['object']).columns
    for col in categorical_cols:
        df[col] = LabelEncoder().fit_transform(df[col])

    # Extract features and labels
    if 'label' in df.columns:
        y = df['label'].astype(int)
        X = df.drop(columns=['label'])
    else:
        y = None
        X = df

    return X, y, X.columns.tolist()

# Function to sample the data based on the size of the dataset
def sample_data(X, y, sample_size_ratio=0.2):
    scaler = StandardScaler()
    X_scaled = scaler.fit_transform(X)

    data_size = len(X_scaled)
    sample_size = int(sample_size_ratio * data_size) if data_size <= 100000 else int(0.1 * data_size)

    if y is not None:
        X_sample, _, y_sample, _ = train_test_split(X_scaled, y, train_size=sample_size, stratify=y, random_state=42)
    else:
        minmax_scaler = MinMaxScaler()
        X_normalized = minmax_scaler.fit_transform(X_scaled)
        sum_scores = np.sum(X_normalized, axis=1)
        sorted_indices = np.argsort(sum_scores)
        low_samples = sorted_indices[:sample_size // 2]
        high_samples = sorted_indices[-(sample_size // 2):]
        selected_indices = np.concatenate((low_samples, high_samples))
        X_sample = X_scaled[selected_indices].reshape(-1, X.shape[1])

    return X_sample

# Function to compute the optimal 'k' for each feature using silhouette scores
def compute_optimal_k(X_sample, feature_names):
    feature_k_values = {}

    for feature_idx, feature_name in enumerate(feature_names):
        X_feature = X_sample[:, feature_idx].reshape(-1, 1)
        k_values = range(2, 12)
        silhouette_scores_list = []

        for k in k_values:
            kmeans = KMeans(n_clusters=k, random_state=42, n_init=10)
            labels = kmeans.fit_predict(X_feature)
            try:
                score = silhouette_score(X_feature, labels)
                silhouette_scores_list.append(score)
            except ValueError:
                silhouette_scores_list.append(-1)

        optimal_k = k_values[np.argmax(silhouette_scores_list)] if max(silhouette_scores_list) > -1 else 1
        feature_k_values[feature_name] = optimal_k

    return feature_k_values

def thermometer_encode(labels, num_levels):
    """
    Thermometer encoding for cluster labels.
    Example: label 3 with levels 5 -> [1,1,1,0,0]
    """
    encoded = np.zeros((len(labels), num_levels), dtype=int)
    for i, label in enumerate(labels):
        encoded[i, :label] = 1
    return encoded
    
