def main(args):
    """Train TM model on 85% training data and evaluate on 15% test data."""

    X, y = load_dataset("Final_folder_medsec/train.csv")

    # ✅ 85-15 split (NO validation)
    X_train, X_test, y_train, y_test = train_test_split(
        X, y, test_size=0.15, random_state=42, stratify=y
    )

    tm = TMClassifier(
        number_of_clauses=args.num_clauses,
        T=args.T,
        s=args.s,
        max_included_literals=args.max_included_literals,
        platform=args.platform,
        weighted_clauses=args.weighted_clauses
    )

    # ---- Training loop (NO early stopping) ----
    for epoch in range(args.epochs):
        tm.fit(X_train, y_train)

        y_pred_train = tm.predict(X_train)
        train_acc = 100 * (y_pred_train == y_train).mean()

        _LOGGER.info(f"Epoch {epoch + 1}: Train Accuracy: {train_acc:.2f}%")

    # ---- Final Evaluation ----
    y_pred_test = tm.predict(X_test)
    test_acc = 100 * (y_pred_test == y_test).mean()
    _LOGGER.info(f"Final Test Accuracy: {test_acc:.2f}%")

    # ---- Inference Time ----
    start_time = time.time()
    num_samples = X_test.shape[0]

    for i in range(num_samples):
        _ = tm.predict(X_test[i].reshape(1, -1))

    end_time = time.time()
    avg_inference_time = (end_time - start_time) / max(num_samples, 1)

    _LOGGER.info(f"Average Inference Time per Sample: {avg_inference_time:.6f} seconds")

    return test_acc, avg_inference_time

