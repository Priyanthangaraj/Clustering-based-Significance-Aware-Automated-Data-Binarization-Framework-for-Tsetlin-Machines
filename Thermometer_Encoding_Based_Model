        _LOGGER.info(f"\n======== TRIAL {i+1}/{num_trials}: KNN/Encoding + TM Pipeline ========")

        # Preprocess & feature names
        X, y, feature_names = preprocess_dataset(merged_csv_path)

        # Decide KNN strategy
        knn_strategy = apply_knn(X)

        # Sample and determine per-feature optimal K
        X_sample = sample_data(X, y)
        assert X_sample.shape[1] == len(feature_names), "❌ Feature count mismatch!"
        optimal_ks = compute_optimal_k(X_sample, feature_names)

        # Display per-feature K (optional, verbose)
        print("\n📊 Optimal K for Each Feature:")
        for feature, k in optimal_ks.items():
            print(f" - {feature}: {k if k else 'Not Computable'}")

        # Encode and produce train/test for this trial
        if knn_strategy == "standard":
            standard_knn_and_encoding(merged_csv_path, optimal_ks, Final_folder="Final_folder_medsec")
        elif knn_strategy == "batchwise":
            # Keep original logic; pass merged_csv_path as input_file
            KNN_batchwise(optimal_ks, merged_csv_path, Final_folder="Final_folder_medsec", batch_size=2000)

        # Build args with manual hyperparameters and run training/eval
        args = default_args()  # already defaults to MANUAL_TM_PARAMS
        test_acc, per_sample_time = main(args)

        accs.append(test_acc)
        times.append(per_sample_time)
        
        # 🔥 SAVE FULL RUN INFO
        run_results.append({
            "Run": i + 1,
            "s": args.s,
            "T": args.T,
            "num_clauses": args.num_clauses,
            "Test Accuracy (%)": round(test_acc, 4),
            "Avg Inference Time (s)": round(per_sample_time, 6)
        })

        _LOGGER.info(f"Trial {i+1} done. Test Acc: {test_acc:.2f}% | Per-sample time: {per_sample_time:.6f}s")

    # Aggregate stats
    acc_mean = float(np.mean(accs))
    acc_std = float(np.std(accs, ddof=1)) if len(accs) > 1 else 0.0
    time_mean = float(np.mean(times))
    time_std = float(np.std(times, ddof=1)) if len(times) > 1 else 0.0

    _LOGGER.info(
        f"\n==== Summary over {num_trials} runs (KNN/Encoding + TM) ====\n"
        f"Test Accuracy: {acc_mean:.2f}% ± {acc_std:.2f}%\n"
        f"Per-sample Inference Time: {time_mean:.6f}s ± {time_std:.6f}s\n"
    )

    print("\n" + "="*74)
    print(f"Summary over {num_trials} runs (KNN/Encoding + Tsetlin Machine)")
    print(f"Test Accuracy: {acc_mean:.2f}% ± {acc_std:.2f}%")
    print(f"Per-sample Inference Time: {time_mean:.6f}s ± {time_std:.6f}s")
    print("="*74 + "\n")

    # ================= SAVE RESULTS =================
    df_results = pd.DataFrame(run_results)
    
    output_path = "Final_folder/MonteCarlo_Detailed_Results.csv"
    df_results.to_csv(output_path, index=False)
    
    print(f"\n✅ Results saved to: {output_path}")

    return {
        "accuracy_mean": acc_mean,
        "accuracy_std": acc_std,
        "inference_time_mean": time_mean,
        "inference_time_std": time_std,
        "all_accuracies": accs,
        "all_times": times,
    }

